# ═══════════════════════════════════════════════════════════════
#  LUMIA — Environment Variables
#  Copy file này, đặt tên .env.local để chạy local
#  Trên Vercel: Settings → Environment Variables → import file này
# ═══════════════════════════════════════════════════════════════

# ── Supabase ─────────────────────────────────────────────────────
# Dashboard: https://supabase.com/dashboard → Project Settings → API

# 1. Project URL
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# 2. Anon / Publishable key  (safe — dùng ở browser)
#    Supabase mới:  "Publishable" tab → sb_publishable_...
#    Supabase cũ:   "anon public"     → eyJh...
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# 3. Service Role / Secret key  (NEVER expose — chỉ server)
#    Supabase mới: "Secret" tab → sb_secret_...
#    Supabase cũ:  "service_role"    → eyJh...
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxx

# ── App URL ──────────────────────────────────────────────────────
# URL production của app — dùng để build absolute URL cho callback PayOS
NEXT_PUBLIC_APP_URL=https://www.lumia.com.vn

# ── LLM / AI ─────────────────────────────────────────────────────
# OpenAI hoặc bất kỳ provider nào tương thích OpenAI
LLM_API_KEY=sk-...
# LLM_BASE_URL=https://api.openai.com/v1   # bỏ comment nếu dùng provider khác
LLM_MODEL=gpt-4o-mini
# LLM_MAX_TOKENS=512
# LLM_TEMPERATURE=0.7

# ── PayOS ────────────────────────────────────────────────────────
# Lấy tại: https://my.payos.vn → Tài khoản → Tích hợp API
#
# Bước setup:
#   1. Điền 3 biến bên dưới
#   2. Set DEMO_MODE=false (hoặc xóa dòng DEMO_MODE)
#   3. Set PAYOS_WEBHOOK_URL = https://<domain>/api/payos/webhook
#   4. Deploy lên server
#   5. Gọi POST /api/admin/payos-webhook (dùng tài khoản admin)
#      để đăng ký webhook URL với PayOS — chỉ cần làm 1 lần sau deploy

# Client ID — tìm ở tab "Tích hợp API" của portal PayOS
PAYOS_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# API Key — tìm ở tab "Tích hợp API" (mục "API Key")
PAYOS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Checksum Key — tìm ở tab "Tích hợp API" (mục "Checksum Key")
PAYOS_CHECKSUM_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Webhook URL — phải là URL public HTTPS, trỏ đúng vào /api/payos/webhook
# PayOS sẽ POST vào URL này sau mỗi giao dịch thành công/thất bại
PAYOS_WEBHOOK_URL=https://www.lumia.com.vn/api/payos/webhook

# ── Bảo mật / Cron ───────────────────────────────────────────────
# Tạo: openssl rand -hex 32
CRON_SECRET=

# ── Demo mode ────────────────────────────────────────────────────
# true  → bỏ qua PayOS, trả về URL checkout giả (dùng khi dev local)
# false → kết nối PayOS thật (bắt buộc khi production)
DEMO_MODE=false

# ── Analytics (tuỳ chọn) ─────────────────────────────────────────
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
