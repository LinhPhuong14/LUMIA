NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# AI — gọi LLM trực tiếp trong Next.js (logic port từ lumia_service_ai)
